PORT=3000
NODE_ENV=development
# Optional: set to a mounted persistent disk path on Render, such as /var/data.
DATA_DIR=
# Production storage. Use Render Postgres for paid pilots and multi-client operation.
DATABASE_URL=
DATABASE_SSL=true
SEND_LIVE_MESSAGES=false
SEND_LIVE_CALENDAR=false
CHECK_CALENDAR_AVAILABILITY=true
PREFER_CUSTOMER_WHATSAPP=false
BUSINESS_NAME="Demo Home Services"
ASSISTANT_NAME=Riley
BUSINESS_INDUSTRY=home services
BUSINESS_SERVICES="repair, inspection, maintenance"
BUSINESS_SERVICE_AREAS="33487, 33485"
# Optional JSON override for the whole profile. Keep secrets out of this value.
BUSINESS_PROFILE_JSON=
BUSINESS_TIMEZONE=America/New_York
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
DEFAULT_APPOINTMENT_MINUTES=60
AVAILABLE_SLOT_INTERVAL_MINUTES=60
MAX_AVAILABLE_SLOTS=3
LEADS_VIEW_KEY=
LEAD_VIEWER_TOKEN=
ADMIN_TOKEN=
# Optional multi-client pilot config. Store per-client viewer tokens here only as env config, not in docs.
CLIENTS_JSON=
RATE_LIMIT_ADMIN_PER_MINUTE=600
RATE_LIMIT_WEBHOOK_PER_MINUTE=180
RATE_LIMIT_DEFAULT_PER_MINUTE=300

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

VAPI_API_KEY=
VAPI_ASSISTANT_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

OWNER_PHONE_NUMBER=
OWNER_WHATSAPP_NUMBER=
